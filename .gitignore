!aland_excluded/run_baypass.sh
!sielva_excluded/run_baypass.sh
!aland_sielva_excluded/run_baypass.sh
out_baypass/
out_baypass_2/
infiles_for_baypass/
el_diem/
data_sim/
*baypass.log
*.out

# other large intermediates
ld_decay_DIEM_100w.rds
keynote/

