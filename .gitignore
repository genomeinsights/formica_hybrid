.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# ============================================================
# Merged Formica pipeline: data / outputs / artifacts (NOT code)
# (data/ is already ignored above)
# ============================================================
.DS_Store
Rplots.pdf
*.zip
*.gds

